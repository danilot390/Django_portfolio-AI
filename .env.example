# ------------------------------------------------------------------------------
# Django
# ------------------------------------------------------------------------------
DEBUG=False
SECRET_KEY=change-me

ALLOWED_HOSTS=danilotr.com,www.danilotr.com
CSRF_TRUSTED_ORIGINS=https://danilotr.com,https://www.danilotr.com

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://portfolio_user:strong_password@localhost:5432/portfolio_db

# ------------------------------------------------------------------------------
# Email / Resend
# ------------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

DEFAULT_FROM_EMAIL=noreply@danilotr.com
SERVER_EMAIL=noreply@danilotr.com
CONTACT_RECEIVER_EMAIL=contact@danilotr.com

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Optional
# ------------------------------------------------------------------------------
BASE_URL=https://www.danilotr.com
PDF_SERVICE_URL=http://pdf-service:3001

# ----------------------------------------------------------------------
# Django Superuser Bootstrap
# ----------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@danilotr.com
DJANGO_SUPERUSER_PASSWORD=<strong-random-password>